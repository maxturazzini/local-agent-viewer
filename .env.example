# Optional - only needed for semantic KB / classification features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QDRANT_URL=http://localhost:6333
CHATGPT_EXPORT_PATH=

# Classification config (all optional — defaults work with OpenAI)
# LAV_CLASSIFY_MODEL=gpt-4.1-mini
# LAV_CLASSIFY_BASE_URL=               # e.g. http://localhost:11434/v1 for Ollama
# LAV_CLASSIFY_SYSTEM_PROMPT=          # inline text or path to .txt file
# LAV_CLASSIFY_MAX_CHARS=12000         # max chars of interaction text sent to model (default: 12000)
# LAV_CLASSIFY_LANGUAGE=en             # language for summary/abstract/process (default: en)

# MCP server authentication
LAV_API_KEY=                     # Required for write operations (sync, kb_index, kb_remove, kb_update_tags)
LAV_READ_API_KEY=                # Required for read operations if set (get_interactions, semantic_search, etc.)
